VITE_API_HOST=/organized
VITE_AUTH_MODE=local

# Self-hosted source-materials mirror, served by nginx on the box.
# When set, JW meeting-material import resolves locally (fully offline).
# If unset, the app falls back to source-materials.organized-app.com.
VITE_SOURCE_MATERIALS_API=/organized-sources

# In-app announcements endpoint. Empty = feature disabled (no third-party
# SaaS). Set to a local URL to self-host announcements.
VITE_NOTIFICATIONS_API=
